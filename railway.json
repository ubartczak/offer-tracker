{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm --filter api build"
  },
  "deploy": {
    "startCommand": "pnpm --filter api db:migrate:deploy && pnpm --filter api start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
